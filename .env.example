# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# OpenAI: used for the LLM in both modes (gpt-4o for final calls, gpt-4o-mini for cheap steps)
OPENAI_API_KEY=

# Anthropic: used for the model-as-judge in the Phase 9 evaluation harness (claude-sonnet-4-6)
ANTHROPIC_API_KEY=

# Finnhub: analyst consensus estimates (price, market cap, earnings calendar)
FINNHUB_API_KEY=

# Financial Modeling Prep: EPS and revenue estimates (Finnhub free-tier backup)
FMP_API_KEY=

# Tavily: news and web search
TAVILY_API_KEY=

# SEC EDGAR requires a real contact string in the User-Agent header.
# Format: "Your Name your.email@example.com"
SEC_USER_AGENT=Your Name your.email@example.com
